# URLs de los microservicios Talki (lado servidor / BFF).
# En el navegador NUNCA se exponen: todas las llamadas pasan por /api/* (BFF).
TALKI_IDENTITY_URL=http://localhost:8081
TALKI_SESSION_URL=http://localhost:8082
TALKI_COACH_URL=http://localhost:8083
TALKI_FILLER_URL=http://localhost:8087
TALKI_SCORING_URL=http://localhost:8088
TALKI_PROGRESS_URL=http://localhost:8089
TALKI_GAMIFICATION_URL=http://localhost:8090
TALKI_NOTIFICATION_URL=http://localhost:8091

# Nombre de la cookie httpOnly donde se guarda el JWT.
TALKI_SESSION_COOKIE=talki_session
