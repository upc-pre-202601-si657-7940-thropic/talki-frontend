# URLs de los microservicios Talki (lado servidor / BFF).
# En el navegador NUNCA se exponen: todas las llamadas pasan por /api/* (BFF).
#
# Opción A — backends locales (docker compose en cada repo talki-*-services):
TALKI_IDENTITY_URL=http://localhost:8081
TALKI_SESSION_URL=http://localhost:8082
TALKI_COACH_URL=http://localhost:8083
TALKI_FILLER_URL=http://localhost:8087
TALKI_SCORING_URL=http://localhost:8088
TALKI_PROGRESS_URL=http://localhost:8089
TALKI_GAMIFICATION_URL=http://localhost:8090
TALKI_NOTIFICATION_URL=http://localhost:8091
#
# Opción B — backends deployados en Railway (Sprint 2). Para usarlos, reemplaza
# los valores de arriba por estos en tu .env.local:
#   TALKI_IDENTITY_URL=https://talki-user-services-production.up.railway.app
#   TALKI_SESSION_URL=https://session-service-production-c267.up.railway.app
#   TALKI_COACH_URL=https://live-coach-service-production.up.railway.app
#   TALKI_FILLER_URL=https://filler-detection-service-production.up.railway.app
#   TALKI_SCORING_URL=https://scoring-service-production-9702.up.railway.app
#   TALKI_PROGRESS_URL=https://progress-service-production-cd14.up.railway.app
#   TALKI_GAMIFICATION_URL=https://gamification-service-production-3c2c.up.railway.app
#   TALKI_NOTIFICATION_URL=https://notification-service-production-a277.up.railway.app

# Nombre de la cookie httpOnly donde se guarda el JWT.
TALKI_SESSION_COOKIE=talki_session
